# SMTP Configuration for Email Sending
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
CONTACT_EMAIL=ngsrepresentaciones@gmail.com

# Static Deployment Configuration (GitHub Pages)
# If deploying to https://<username>.github.io/<repo-name>/, set to /<repo-name>/
VITE_BASE_URL=/

# Formspree ID for static contact form (optional)
# Get one at https://formspree.io/
VITE_FORMSPREE_ID=
